{
  "expo": {
    "name": "BetTeam",
    "slug": "betteam",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.betteam.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1A"
      },
      "package": "com.betteam.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ]
  }
}
